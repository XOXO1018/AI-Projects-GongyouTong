<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_background"
        android:elevation="0dp"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/text_primary"
        app:title="日程详情"
        app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider_subtle" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="100dp">

            <!-- 顶部：日程来源 + 状态 + 标题 + 类型 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background"
                app:strokeWidth="0.5dp"
                app:strokeColor="@color/outline_variant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- 日程来源 + 状态 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvScheduleSource"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="日程"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_workorder_status_tag"
                            android:backgroundTint="@color/workorder_tag_bg"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp"
                            android:text="待出发"
                            android:textColor="@color/workorder_pending"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- 标题 -->
                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="安装热水器"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <!-- 工作类型标签 -->
                    <TextView
                        android:id="@+id/tvWorkType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_tag_primary"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="安装服务"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- 日程进度时间线 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/timelineDot1"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_step_circle"
                            android:backgroundTint="@color/workorder_pending" />

                        <View
                            android:id="@+id/timelineLine1"
                            android:layout_width="0dp"
                            android:layout_height="2.5dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:background="@color/gray_200" />

                        <View
                            android:id="@+id/timelineDot2"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_step_circle"
                            android:backgroundTint="@color/gray_300" />

                        <View
                            android:id="@+id/timelineLine2"
                            android:layout_width="0dp"
                            android:layout_height="2.5dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:background="@color/gray_200" />

                        <View
                            android:id="@+id/timelineDot3"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_step_circle"
                            android:backgroundTint="@color/gray_300" />

                    </LinearLayout>

                    <!-- 时间线标签 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="待出发"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="进行中"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="已完成"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 客户信息 + 地址 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCustomer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/card_background"
                app:strokeWidth="0.5dp"
                app:strokeColor="@color/outline_variant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="客户信息"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddCustomer"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="添加"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:visibility="gone"
                            app:icon="@drawable/ic_add"
                            app:iconSize="14dp"
                            app:iconTint="@color/primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutCustomerInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvContactAvatar"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:gravity="center"
                            android:background="@drawable/bg_workorder_status_tag"
                            android:backgroundTint="@color/primary_container"
                            android:textColor="@color/primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvContactName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvContactPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnContact"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="14dp"
                            android:text="联系客户"
                            android:textSize="12sp"
                            app:cornerRadius="10dp"
                            app:backgroundTint="@color/primary_container"
                            app:icon="@drawable/ic_phone_contact"
                            app:iconSize="14dp"
                            app:iconTint="@color/primary" />

                    </LinearLayout>

                    <View
                        android:id="@+id/dividerCustomer"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="14dp"
                        android:background="@color/divider_subtle"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="服务地址"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="地址待确认"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvAppointmentTime"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:drawablePadding="6dp"
                            android:text="预约：时间待定"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvCountdown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/status_progress_text"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNavigate"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="12dp"
                        android:text="导航前往"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/primary"
                        app:icon="@drawable/ic_navigation"
                        app:iconSize="18dp"
                        app:iconTint="@color/primary" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 任务描述 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/card_background"
                app:strokeWidth="0.5dp"
                app:strokeColor="@color/outline_variant"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="任务描述"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 设备信息 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDeviceInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/card_background"
                app:strokeWidth="0.5dp"
                app:strokeColor="@color/outline_variant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="设备信息"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddDevice"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="添加"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:visibility="gone"
                            app:icon="@drawable/ic_add"
                            app:iconSize="14dp"
                            app:iconTint="@color/primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutDeviceInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/equipment_label_bg"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="设备品牌"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvDeviceBrand"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/equipment_label_bg"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="设备型号"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvDeviceModel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/equipment_label_bg"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="使用年限"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvDeviceAge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- AI 智能提醒 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutAiReminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/bg_ai_card"
                app:strokeColor="@color/card_ai_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="AI 智能提醒"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAiModel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="蓝心大模型"
                            android:textColor="@color/primary"
                            android:textSize="11sp"
                            android:layout_marginEnd="10dp" />

                        <ProgressBar
                            android:id="@+id/pbAiReminder"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:visibility="gone" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRefreshAi"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="重新生成"
                            android:textColor="@color/primary"
                            android:textSize="11sp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="10dp"
                            app:icon="@drawable/ic_refresh"
                            app:iconSize="14dp"
                            app:iconTint="@color/primary" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAiReminder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="AI 正在生成个性化提醒..."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.5"
                        android:maxLines="4"
                        android:ellipsize="end" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExpandReminder"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="展开全文"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="6dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvToolsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="所需工具"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupTools"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:chipSpacingHorizontal="10dp"
                        app:chipSpacingVertical="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 风险提示 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRiskWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/ai_risk_card_bg"
                app:strokeColor="@color/ai_risk_border"
                app:strokeWidth="1dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="风险提示"
                            android:textColor="@color/risk_high_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRiskLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_workorder_status_tag"
                            android:backgroundTint="@color/risk_high_bg"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:textColor="@color/risk_high_text"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRiskContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 底部固定操作栏 -->
    <LinearLayout
        android:id="@+id/layoutBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/toolbar_background"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartTask"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="开始任务"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_navigation"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/white" />

    </LinearLayout>

</LinearLayout>
