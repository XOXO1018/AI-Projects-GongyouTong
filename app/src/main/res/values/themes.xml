<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- === 工友通 v3 日间主题 — 精工工业风 · 柔化质感 === -->
    <style name="Theme.GongyouTong" parent="Theme.Material3.Light.NoActionBar">
        <!-- 品牌色 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- 辅助色 -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <!-- 第三色 -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        <item name="colorOnTertiaryContainer">@color/on_tertiary_container</item>

        <!-- 背景色 -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- 状态栏 -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <!-- 导航栏 -->
        <item name="android:navigationBarColor">@color/nav_bar_background</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- 错误色 -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>

        <!-- 描边 -->
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>

        <!-- 全局按钮涟漪 -->
        <item name="colorControlHighlight">@color/primary_200</item>

        <!-- Android 15 边到边 -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="v">true</item>
    </style>

    <!-- 导航主题（日间） -->
    <style name="Theme.GongyouTong.Navigation" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="android:colorBackground">@color/nav_page_bg</item>
        <item name="colorSurface">@color/nav_page_card</item>
        <item name="colorOnSurface">@color/nav_page_text</item>
        <item name="colorOnSurfaceVariant">@color/nav_page_subtext</item>
        <item name="android:statusBarColor">@color/nav_page_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/nav_page_card</item>
        <item name="colorOutline">@color/nav_page_divider</item>
        <item name="colorControlHighlight">@color/primary_200</item>
    </style>

    <!-- === 卡片样式 === -->
    <style name="Widget.GongyouTong.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <style name="Widget.GongyouTong.Card.Primary" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/primary</item>
    </style>

    <style name="Widget.GongyouTong.Card.AI" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/card_ai_background</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/card_ai_border</item>
    </style>

    <!-- === 按钮样式 === -->
    <style name="Widget.GongyouTong.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textFontWeight">500</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="rippleColor">@color/primary_200</item>
    </style>

    <style name="Widget.GongyouTong.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textFontWeight">500</item>
        <item name="backgroundTint">@color/primary_container</item>
        <item name="android:textColor">@color/on_primary_container</item>
        <item name="rippleColor">@color/primary_200</item>
    </style>

    <style name="Widget.GongyouTong.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textFontWeight">500</item>
        <item name="strokeColor">@color/outline</item>
        <item name="android:textColor">@color/primary</item>
        <item name="rippleColor">@color/primary_200</item>
    </style>

    <style name="Widget.GongyouTong.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textColor">@color/primary</item>
        <item name="rippleColor">@color/primary_200</item>
    </style>

    <style name="Widget.GongyouTong.Button.Success" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/success</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textFontWeight">500</item>
        <item name="rippleColor">@color/success_light</item>
    </style>

    <style name="Widget.GongyouTong.Button.Danger" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/error</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textFontWeight">500</item>
        <item name="rippleColor">@color/error_container</item>
    </style>

    <!-- === 输入框样式 === -->
    <style name="Widget.GongyouTong.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/input_focus_stroke</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <!-- === 底部导航样式 === -->
    <style name="Widget.GongyouTong.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/nav_bar_background</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">8dp</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.GongyouTong.BottomNav.ActiveIndicator</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="Widget.GongyouTong.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_container</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- === 状态标签 === -->
    <style name="Widget.GongyouTong.StatusBadge.Pending" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:background">@drawable/bg_status_badge_pending</item>
        <item name="android:textColor">@color/status_pending_text</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="Widget.GongyouTong.StatusBadge.InProgress" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:background">@drawable/bg_status_badge_in_progress</item>
        <item name="android:textColor">@color/status_progress_text</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="Widget.GongyouTong.StatusBadge.Completed" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:background">@drawable/bg_status_badge_completed</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <!-- === Chip 样式 === -->
    <style name="Widget.GongyouTong.Chip.AI" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipCornerRadius">18dp</item>
        <item name="chipBackgroundColor">@color/card_ai_background</item>
        <item name="chipStrokeColor">@color/card_ai_border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="rippleColor">@color/primary_200</item>
    </style>

    <!-- === Toolbar 样式 === -->
    <style name="Widget.GongyouTong.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- === Dialog 样式 === -->
    <style name="Theme.GongyouTong.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.GongyouTong.Dialog</item>
    </style>

    <style name="ShapeAppearance.GongyouTong.Dialog" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerSize">24dp</item>
    </style>

    <!-- === Snackbar 样式 === -->
    <style name="Widget.GongyouTong.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/gray_900</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>
</resources>
